<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lonoy Agriventures Corporation</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #2d6a4f;
      --primary-light: #40916c;
      --accent: #52b788;
      --light: #d8f3dc;
      --white: #ffffff;
      --gray: #f8f9fa;
      --dark: #1b4332;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      line-height: 1.6;
      color: #333;
      overflow-x: hidden;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    /* Navigation - Already sticky */
    header {
      background: var(--white);
      box-shadow: 0 2px 20px rgba(0,0,0,0.1);
      position: fixed;
      top: 0;
      width: 100%;
      z-index: 1000;
    }

    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
    }

    .logo {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--primary);
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      list-style: none;
      gap: 2rem;
    }

    .nav-links a {
      text-decoration: none;
      color: var(--dark);
      font-weight: 500;
      transition: color 0.3s ease;
    }

    .nav-links a:hover {
      color: var(--primary);
    }

    .hamburger {
      display: none;
      flex-direction: column;
      cursor: pointer;
    }

    .hamburger span {
      width: 25px;
      height: 3px;
      background: var(--primary);
      margin: 3px 0;
      transition: 0.3s;
    }

    /* Hero Section - Enhanced gradient */
    .hero {
      background: linear-gradient(135deg, 
        var(--primary) 0%, 
        var(--primary-light) 40%, 
        var(--accent) 100%);
      color: var(--white);
      padding: 140px 0 100px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.1) 0%, transparent 50%);
      pointer-events: none;
    }

    .hero h1 {
      font-size: 3.5rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      line-height: 1.2;
    }

    .hero p {
      font-size: 1.3rem;
      margin-bottom: 2.5rem;
      opacity: 0.95;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-buttons {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      padding: 14px 35px;
      border: none;
      border-radius: 50px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s ease;
      cursor: pointer;
      font-size: 1.1rem;
    }

    .btn-primary {
      background: var(--accent);
      color: var(--white);
      box-shadow: 0 4px 15px rgba(82, 183, 136, 0.3);
    }

    .btn-primary:hover {
      background: var(--light);
      color: var(--primary);
      transform: translateY(-3px);
      box-shadow: 0 6px 20px rgba(82, 183, 136, 0.4);
    }

    .btn-outline {
      background: transparent;
      color: var(--white);
      border: 2px solid var(--white);
      box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2);
    }

    .btn-outline:hover {
      background: var(--white);
      color: var(--primary);
      transform: translateY(-3px);
      box-shadow: 0 6px 20px rgba(255, 255, 255, 0.3);
    }

    /* Sections - Increased spacing */
    section {
      padding: 100px 0;
    }

    .section-title {
      text-align: center;
      font-size: 2.8rem;
      color: var(--primary);
      margin-bottom: 4rem;
      position: relative;
    }

    .section-title::after {
      content: '';
      display: block;
      width: 80px;
      height: 4px;
      background: var(--accent);
      margin: 1.5rem auto;
      border-radius: 2px;
    }

    /* About Section */
    .about {
      background: var(--gray);
    }

    .about-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .about-text {
      font-size: 1.15rem;
      line-height: 1.8;
    }

    .about-text p {
      margin-bottom: 1.5rem;
    }

    .about-image {
      background: linear-gradient(135deg, var(--light) 0%, var(--accent) 100%);
      height: 350px;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 5rem;
      color: var(--white);
      box-shadow: 0 10px 30px rgba(45, 106, 79, 0.15);
    }

    /* Pillars Section */
    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2.5rem;
    }

    .pillar-card {
      background: var(--white);
      padding: 2.5rem 2rem;
      border-radius: 20px;
      text-align: center;
      box-shadow: 0 8px 25px rgba(0,0,0,0.08);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border: 1px solid rgba(216, 243, 220, 0.3);
    }

    .pillar-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 15px 35px rgba(0,0,0,0.15);
      border-color: var(--accent);
    }

    .pillar-icon {
      font-size: 3.5rem;
      margin-bottom: 1.5rem;
    }

    .pillar-card h3 {
      color: var(--primary);
      margin-bottom: 1.2rem;
      font-size: 1.5rem;
    }

    .pillar-card p {
      color: #666;
      line-height: 1.7;
    }

    /* Products Section */
    .products {
      background: var(--gray);
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2.5rem;
    }

    .product-card {
      background: var(--white);
      padding: 2.5rem 2rem;
      border-radius: 20px;
      text-align: center;
      box-shadow: 0 8px 25px rgba(0,0,0,0.08);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border: 1px solid rgba(216, 243, 220, 0.3);
    }

    .product-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 15px 35px rgba(0,0,0,0.15);
      border-color: var(--accent);
    }

    .product-icon {
      font-size: 3.5rem;
      margin-bottom: 1.5rem;
    }

    .product-card h3 {
      color: var(--primary);
      margin-bottom: 1.2rem;
      font-size: 1.5rem;
    }

    .product-card p {
      color: #666;
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }

    .btn-download {
      background: var(--primary);
      color: var(--white);
      padding: 12px 25px;
      border: none;
      border-radius: 25px;
      cursor: pointer;
      transition: all 0.3s ease;
      font-weight: 600;
      font-size: 1rem;
      box-shadow: 0 4px 15px rgba(45, 106, 79, 0.2);
    }

    .btn-download:hover {
      background: var(--primary-light);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(45, 106, 79, 0.3);
    }

    /* Gallery Section */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }

    .gallery-item {
      background: linear-gradient(135deg, var(--light) 0%, var(--accent) 100%);
      height: 220px;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 4.5rem;
      color: var(--white);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }

    .gallery-item:hover {
      transform: translateY(-8px) scale(1.03);
      box-shadow: 0 15px 35px rgba(0,0,0,0.15);
    }

    /* Contact Section */
    .contact {
      background: var(--gray);
    }

    .contact-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    .contact-form {
      background: var(--white);
      padding: 2.5rem;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .form-group {
      margin-bottom: 1.8rem;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.6rem;
      font-weight: 600;
      color: var(--dark);
    }

    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 14px;
      border: 2px solid #e9ecef;
      border-radius: 10px;
      font-size: 1rem;
      transition: all 0.3s ease;
      font-family: 'Inter', sans-serif;
    }

    .form-group input:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(45, 106, 79, 0.1);
    }

    .contact-info {
      padding: 2.5rem;
    }

    .contact-info h3 {
      color: var(--primary);
      margin-bottom: 2rem;
      font-size: 1.8rem;
    }

    .contact-details {
      margin-bottom: 2.5rem;
    }

    .contact-details p {
      margin-bottom: 1.2rem;
      display: flex;
      align-items: center;
      gap: 0.8rem;
      font-size: 1.1rem;
    }

    .social-link {
      color: var(--primary);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.8rem;
      transition: all 0.3s ease;
      font-weight: 600;
      font-size: 1.1rem;
      padding: 10px 15px;
      border-radius: 10px;
      background: var(--white);
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .social-link:hover {
      color: var(--primary-light);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }

    /* Footer */
    footer {
      background: var(--dark);
      color: var(--white);
      padding: 4rem 0 2rem;
    }

    .footer-content {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 4rem;
      margin-bottom: 3rem;
    }

    .footer-logo {
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
    }

    .footer-content p {
      opacity: 0.9;
      line-height: 1.7;
    }

    .footer-links {
      list-style: none;
    }

    .footer-links li {
      margin-bottom: 0.8rem;
    }

    .footer-links a {
      color: var(--light);
      text-decoration: none;
      transition: all 0.3s ease;
      opacity: 0.9;
    }

    .footer-links a:hover {
      color: var(--accent);
      opacity: 1;
      padding-left: 5px;
    }

    .footer-bottom {
      text-align: center;
      padding-top: 3rem;
      border-top: 1px solid rgba(255,255,255,0.15);
    }

    .watermelon {
      font-size: 1.3rem;
      margin-top: 0.5rem;
      display: inline-block;
      animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-5px); }
    }

    /* Responsive Design */
    @media (max-width: 768px) {
      .nav-links {
        display: none;
        flex-direction: column;
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        background: var(--white);
        padding: 1.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      }

      .nav-links.active {
        display: flex;
      }

      .hamburger {
        display: flex;
      }

      .hero {
        padding: 120px 0 80px;
      }

      .hero h1 {
        font-size: 2.5rem;
      }

      .hero p {
        font-size: 1.1rem;
      }

      .section-title {
        font-size: 2.2rem;
        margin-bottom: 3rem;
      }

      .about-content,
      .contact-content {
        grid-template-columns: 1fr;
        gap: 3rem;
      }

      .footer-content {
        grid-template-columns: 1fr;
        gap: 3rem;
      }

      .hero-buttons {
        flex-direction: column;
        align-items: center;
      }

      .btn {
        width: 220px;
      }

      .about-image {
        height: 250px;
        font-size: 4rem;
      }

      .pillars-grid,
      .products-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .gallery-grid {
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      }
    }

    /* Smooth Scrolling */
    html {
      scroll-behavior: smooth;
      scroll-padding-top: 80px;
    }

    /* Additional spacing for sections */
    .pillars,
    .gallery {
      padding: 100px 0;
    }
  </style>
</head>
<body>
  <!-- Navigation -->
  <header>
    <div class="container">
      <nav>
        <a href="#" class="logo">🌱 Lonoy Agriventures</a>
        <ul class="nav-links">
          <li><a href="#about">About</a></li>
          <li><a href="#pillars">Pillars</a></li>
          <li><a href="#products">Products</a></li>
          <li><a href="#gallery">Gallery</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
        <div class="hamburger">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </nav>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <h1>Growing Sustainably, Nurturing Communities</h1>
      <p>47+ years of organic farming, aquaculture, and TESDA-accredited education in Sapian, Capiz.</p>
      <div class="hero-buttons">
        <a href="#about" class="btn btn-primary">Learn More</a>
        <a href="#contact" class="btn btn-outline">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="about">
    <div class="container">
      <h2 class="section-title">Our Story</h2>
      <div class="about-content">
        <div class="about-text">
          <p>Lonoy Agriventures Corporation is a family-owned agribusiness with a legacy spanning over 47 years. We operate an organic farm, a thriving fish pond, and a TESDA-accredited training center in Barangay Lonoy, Citio Asag, Sapian, Capiz.</p>
          <p>We are committed to organic farming, environmental sustainability, community employment, and education through our TESDA programs in Organic Agriculture Production NC II.</p>
        </div>
        <div class="about-image">
          🌾
        </div>
      </div>
    </div>
  </section>

  <!-- Pillars Section -->
  <section id="pillars" class="pillars">
    <div class="container">
      <h2 class="section-title">Our Pillars</h2>
      <div class="pillars-grid">
        <div class="pillar-card">
          <div class="pillar-icon">🌱</div>
          <h3>Organic Farming</h3>
          <p>Chemical-free, sustainable agriculture practices that respect nature and produce healthy crops.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">❤️</div>
          <h3>Health & Wellness</h3>
          <p>Nourishing bodies and communities with fresh, organic produce and sustainable practices.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">🌍</div>
          <h3>Sustainability</h3>
          <p>Caring for the earth and preserving natural resources for future generations.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">💼</div>
          <h3>Employment</h3>
          <p>Creating jobs and economic opportunities through the agricultural value chain.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">🎓</div>
          <h3>Education</h3>
          <p>TESDA-accredited training programs in Organic Agriculture Production NC II.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section id="products" class="products">
    <div class="container">
      <h2 class="section-title">Our Products & Services</h2>
      <div class="products-grid">
        <div class="product-card">
          <div class="product-icon">🥬</div>
          <h3>Organic Vegetables</h3>
          <p>Fresh, chemical-free produce grown with sustainable farming methods.</p>
          <button class="btn-download" onclick="downloadFile('vegetables')">Download Catalog</button>
        </div>
        <div class="product-card">
          <div class="product-icon">🐟</div>
          <h3>Aquaculture Products</h3>
          <p>Sustainably raised fish from our 47+ year old fish pond operation.</p>
          <button class="btn-download" onclick="downloadFile('aquaculture')">Download Catalog</button>
        </div>
        <div class="product-card">
          <div class="product-icon">📘</div>
          <h3>Organic E-Book</h3>
          <p>Learn the basics of organic farming with our comprehensive guide.</p>
          <button class="btn-download" onclick="downloadFile('ebook')">Download E-Book</button>
        </div>
        <div class="product-card">
          <div class="product-icon">📗</div>
          <h3>TESDA Training Guide</h3>
          <p>Complete guide for NC II certification in Organic Agriculture Production.</p>
          <button class="btn-download" onclick="downloadFile('tesda')">Download Guide</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Section -->
  <section id="gallery" class="gallery">
    <div class="container">
      <h2 class="section-title">Gallery</h2>
      <div class="gallery-grid">
        <div class="gallery-item">🌾</div>
        <div class="gallery-item">🐟</div>
        <div class="gallery-item">🌿</div>
        <div class="gallery-item">🧑‍🌾</div>
        <div class="gallery-item">🌱</div>
        <div class="gallery-item">📚</div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="contact">
    <div class="container">
      <h2 class="section-title">Contact Us</h2>
      <div class="contact-content">
        <div class="contact-form">
          <form id="contactForm">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required>
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required>
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" required>
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Send Message</button>
          </form>
        </div>
        <div class="contact-info">
          <h3>Get in Touch</h3>
          <div class="contact-details">
            <p>📍 Lonoy Ponds Aqua Farm, Barangay Lonoy, Citio Asag, Sapian, Capiz</p>
            <p>🎓 TESDA-accredited training institution</p>
          </div>
          <a href="https://www.facebook.com/profile.php?id=61573528071901" target="_blank" class="social-link">
            📘 Facebook Page
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="container">
      <div class="footer-content">
        <div>
          <div class="footer-logo">🌱 Lonoy Agriventures</div>
          <p>47+ years of sustainable agriculture and community development in Sapian, Capiz.</p>
        </div>
        <div>
          <h4>Quick Links</h4>
          <ul class="footer-links">
            <li><a href="#about">About</a></li>
            <li><a href="#pillars">Pillars</a></li>
            <li><a href="#products">Products</a></li>
            <li><a href="#gallery">Gallery</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>
        </div>
        <div>
          <h4>Connect</h4>
          <ul class="footer-links">
            <li><a href="https://www.facebook.com/profile.php?id=61573528071901" target="_blank">Facebook</a></li>
            <li><a href="#contact">Email</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 Lonoy Agriventures Corporation. All rights reserved.</p>
        <p>Built with ❤️ using Open Source <span class="watermelon">🍉</span></p>
      </div>
    </div>
  </footer>

  <script>
    // Mobile Navigation
    const hamburger = document.querySelector('.hamburger');
    const navLinks = document.querySelector('.nav-links');

    hamburger.addEventListener('click', () => {
      navLinks.classList.toggle('active');
    });

    // Close mobile menu when clicking on links
    document.querySelectorAll('.nav-links a').forEach(link => {
      link.addEventListener('click', () => {
        navLinks.classList.remove('active');
      });
    });

    // Form Submission
    document.getElementById('contactForm').addEventListener('submit', function(e) {
      e.preventDefault();
      alert('Thank you for your message! We will get back to you soon.');
      this.reset();
    });

    // Download buttons
    function downloadFile(type) {
      alert(`Thank you for your interest! The ${type} file would download here.`);
    }

    // Add smooth scroll offset for fixed header
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const targetId = this.getAttribute('href');
        if(targetId === '#') return;
        
        const targetElement = document.querySelector(targetId);
        if(targetElement) {
          const headerHeight = document.querySelector('header').offsetHeight;
          const targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset - headerHeight;
          
          window.scrollTo({
            top: targetPosition,
            behavior: 'smooth'
          });
        }
      });
    });
  </script>
</body>
</html>

